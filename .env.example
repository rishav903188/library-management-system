PORT = 5000
#MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Email (Mailtrap sandbox credentials)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME

# Redis
REDIS_URL=redis://localhost:6379

# Cron Schedules (optional — defaults already set in code)
# Testing ke liye har 2 minute: */2 * * * *
# Production: 0 9 * * * (9 AM) aur 0 0 * * * (midnight)
DUE_CHECK_SCHEDULE=0 9 * * *
OVERDUE_FINE_SCHEDULE=0 0 * * *